# ===========================================
# Lindorm Memobase Configuration
# ===========================================
# Copy this file to config.yaml and customize as needed
# Deployment configs (URLs, models, hosts) should be in .env file
# Priority: Environment variables > config.yaml > defaults

# === Feature Toggles ===
enable_event_embedding: true

# === Memobase Configuration ===
language: en  # Options: en, zh
max_profile_subtopics: 15  # Maximum number of subtopics per topic
minimum_chats_token_size_for_event_summary: 256  # Minimum token size to trigger event summary

# === Buffer Management Configuration ===
max_chat_blob_buffer_token_size: 1536  # Auto-trigger processing when buffer reaches this size
max_chat_blob_buffer_process_token_size: 16384  # Maximum token size for single processing batch
lindorm_buffer_pool_size: 32  # Database connection pool size (increase for high concurrency)

# === Profile Management Settings ===
profile_strict_mode: true
profile_validate_mode: true
event_theme_requirement: "Focus on the user's infos, not its instructions. Do not mix up with the bot/assistant's infos"

# === Advanced: Fine-grained LLM Model Selection ===
# Recommended strategy: Use weaker/cheaper model for entry summary, stronger model for extraction/merging
# All fields are optional and fall back to best_llm_model if not set

# entry_llm_model: qwen-plus          # Entry summary (extracting events from conversations) - can use weaker/cheaper model
# extract_llm_model: qwen-max          # Profile extraction (extracting structured facts) - should use stronger model  
# event_llm_model: qwen-max            # Event tagging (tagging events with attributes) - should use stronger model
# merge_llm_model: qwen-max            # Profile merging and validation - should use stronger model

# Deprecated: Use entry_llm_model instead
# summary_llm_model: qwen-max-latest

# === User Profile Schema ===
# Define custom profile topics and subtopics
overwrite_user_profiles:
  - topic: "basic_info"
    sub_topics:
      - name: "gender"
      - name: "name"
      - name: "birth_date"
      - name: "location"
  - topic: "personal_narrative"
    sub_topics:
      - name: "identity_journey"
      - name: "self_acceptance"
      - name: "emotional_states"
      - name: "life_milestones"
  - topic: "life_circumstances"
    sub_topics:
      - name: "career"
      - name: "education"
      - name: "family_status"
      - name: "living_situation"
  - topic: "personal_growth"
    sub_topics:
      - name: "hobbies"
      - name: "creative_pursuits"
      - name: "mental_health"
      - name: "self_care_activities"
  - topic: "plans"
    sub_topics:
      - name: "career_goals"
      - name: "personal_aspirations"
      - name: "family_planning"
      - name: "life_goals"
