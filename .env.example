# ===========================================
# Lindorm Memobase Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual credentials
# Priority: Environment variables > config.yaml > defaults

# === LLM Authentication ===
# For LindormAI, these are your Lindorm credentials
MEMOBASE_LINDORM_USERNAME=root
MEMOBASE_LINDORM_PASSWORD=your_lindorm_password_here

# For OpenAI-compatible APIs
MEMOBASE_LLM_API_KEY=your_llm_api_key_here

# === Embedding Authentication ===
# Leave empty if using same credentials as LLM
MEMOBASE_EMBEDDING_API_KEY=your_embedding_api_key_here

# === Lindorm Table (Wide Table) Credentials ===
MEMOBASE_LINDORM_TABLE_HOST=your-lindorm-table-host.lindorm.aliyuncs.com
MEMOBASE_LINDORM_TABLE_PORT=33060
MEMOBASE_LINDORM_TABLE_USERNAME=root
MEMOBASE_LINDORM_TABLE_PASSWORD=your_table_password_here
MEMOBASE_LINDORM_TABLE_DATABASE=default

# === Lindorm Buffer Table Credentials ===
# Usually same as table credentials
MEMOBASE_LINDORM_BUFFER_HOST=your-lindorm-table-host.lindorm.aliyuncs.com
MEMOBASE_LINDORM_BUFFER_PORT=33060
MEMOBASE_LINDORM_BUFFER_USERNAME=root
MEMOBASE_LINDORM_BUFFER_PASSWORD=your_buffer_password_here
MEMOBASE_LINDORM_BUFFER_DATABASE=default

# === Lindorm Search Credentials ===
MEMOBASE_LINDORM_SEARCH_HOST=your-lindorm-search-host.lindorm.aliyuncs.com
MEMOBASE_LINDORM_SEARCH_PORT=30070
MEMOBASE_LINDORM_SEARCH_USERNAME=root
MEMOBASE_LINDORM_SEARCH_PASSWORD=your_search_password_here
MEMOBASE_LINDORM_SEARCH_USE_SSL=false

# === LLM Service Configuration ===
MEMOBASE_LLM_STYLE=lindormai
MEMOBASE_LLM_BASE_URL=http://your-lindorm-ai-url.lindorm.aliyuncs.com:9002/dashscope/compatible-mode/v1
MEMOBASE_BEST_LLM_MODEL=qwen-max-latest
MEMOBASE_SUMMARY_LLM_MODEL=qwen-max-latest

# === Embedding Service Configuration ===
MEMOBASE_EMBEDDING_PROVIDER=lindormai
MEMOBASE_EMBEDDING_BASE_URL=http://your-lindorm-ai-url.lindorm.aliyuncs.com:9002/dashscope/compatible-mode/v1
MEMOBASE_EMBEDDING_MODEL=text-embedding-v4
MEMOBASE_EMBEDDING_DIM=1024

# === Lindorm Search Index Names ===
MEMOBASE_LINDORM_SEARCH_EVENTS_INDEX=memobase_events
MEMOBASE_LINDORM_SEARCH_EVENT_GISTS_INDEX=memobase_event_gists

# === Legacy Environment Variables (for backward compatibility) ===
# These are used by locomo-benchmark scripts
LINDORM_USERNAME=root
LINDORM_PASSWORD=your_lindorm_password_here
LINDORM_AI_URL=http://your-lindorm-ai-url.lindorm.aliyuncs.com:9002/dashscope/compatible-mode/v1
MODEL=qwen-max-latest
